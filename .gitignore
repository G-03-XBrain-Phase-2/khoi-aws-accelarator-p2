# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and secrets. These should not be part of version 
# control as they are data, not configuration. For templates, also create a 
# variables.tf file and variables.tf.example
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used for local overriding.
# Supported formats are ".tf", ".tf.json", ".tgz", ".zip"
*.override.tf
*.override.tf.json
*_override.tf
*_override.tf.json

# Include override files you do wish to add to version control using negated pattern
# !override.tf

# Include microcharity variables if any
.env
.env.*

# Include OS files
.DS_Store
Thumbs.db

# Docker
.dockerignore

# Kubernetes/minikube local states
.minikube/
.kube/

# Key files and local generated certificates
*.pem
*.key

# Specific practice lab outputs
**/practice/project_metadata.json
